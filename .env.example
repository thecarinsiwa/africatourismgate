# Database (MySQL)
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_NAME=africatourismgate
# On API startup: import database/africatourismgate_database.sql if no tables exist (set false to disable)
DATABASE_AUTO_SCHEMA=true
# On API startup: import database/seeds/install.seed.sql if no users exist (set false to disable)
DATABASE_AUTO_SEED=true

# API (NestJS) — apps/api
API_PORT=3000
API_GLOBAL_PREFIX=api

# Next.js apps — public URL of the API (browser + server)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# CORS (comma-separated origins, or leave unset for reflect permissive dev default in code)
# CORS_ORIGIN=http://localhost:3001,http://localhost:3002,http://localhost:3003

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
