# Copy to .env on the VPS: cp .env.production.example .env
# Then edit secrets and domain URLs before the first deploy.

NODE_ENV=production

# Database (MySQL on the same VPS or managed DB)
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=atg
DATABASE_PASSWORD=change-me
DATABASE_NAME=africatourismgate
# Disable after the first successful API boot (schema + seeds already applied)
DATABASE_AUTO_SCHEMA=false
DATABASE_AUTO_SEED=false
DATABASE_LOGGING=false

# API (NestJS) — internal port; nginx proxies api.africatourismgate.org → this port
API_PORT=3000
API_GLOBAL_PREFIX=api

# Public URLs (Next.js build reads these from repo root .env — run `pnpm build` after changes)
NEXT_PUBLIC_API_URL=https://api.africatourismgate.org/api
# Site public (apps/web, nginx → port 3002) — pas de /login ici
NEXT_PUBLIC_WEB_URL=https://africatourismgate.org
# Back-office admin (apps/admin, nginx → port 3001)
NEXT_PUBLIC_ADMIN_URL=https://app-africatourismgate.org

# CORS — origins allowed to call the API (include www variants if used)
CORS_ORIGIN=https://africatourismgate.org,https://www.africatourismgate.org,https://app-africatourismgate.org,https://www.app-africatourismgate.org

JWT_ACCESS_SECRET=generate-a-long-random-string
JWT_REFRESH_SECRET=generate-another-long-random-string

# PM2 optional POS (heavier — enable only if needed 24/7)
# ATG_ENABLE_POS=1
